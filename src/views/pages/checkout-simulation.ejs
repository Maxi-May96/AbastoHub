<!DOCTYPE html>
<html lang="es" class="h-full bg-[#f5f5f5] text-slate-900">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Simulador de Pago — Mercado Pago</title>
  
  <!-- Fonts: Outfit (Header) & Inter (Body) -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    .display-font {
      font-family: 'Outfit', sans-serif;
    }
  </style>
</head>
<body class="flex flex-col h-full bg-[#eceff1]">

  <!-- Header of Mercado Pago Simulation -->
  <header class="w-full bg-[#009ee3] text-white py-4 shadow-md">
    <div class="max-w-4xl mx-auto px-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <i class="fa-solid fa-handshake-simple text-2xl"></i>
        <span class="display-font text-xl font-black italic tracking-tight">
          mercado <span class="font-light">pago</span>
        </span>
      </div>
      <span class="text-xs bg-white/20 px-2.5 py-1 rounded-full font-bold uppercase tracking-wider">
        <i class="fa-solid fa-bug text-[10px] mr-1"></i> Modo Simulado MVP
      </span>
    </div>
  </header>

  <!-- Main Container -->
  <main class="flex-grow flex items-center justify-center p-4 sm:p-8">
    <div class="w-full max-w-lg bg-white rounded-3xl shadow-xl border border-slate-200 overflow-hidden">
      
      <!-- Seller / Purchase Banner -->
      <div class="bg-slate-50 border-b border-slate-100 p-6 flex items-center justify-between">
        <div>
          <span class="text-[10px] text-slate-400 uppercase font-bold tracking-wider">Vendedor</span>
          <h2 class="display-font text-base font-extrabold text-slate-800 flex items-center gap-1.5 mt-0.5">
            <span class="text-[#009ee3]"><i class="fa-solid fa-store"></i></span>
            AbastoHub S.R.L.
          </h2>
        </div>
        <div class="text-right">
          <span class="text-[10px] text-slate-450 uppercase font-bold tracking-wider">Total a pagar</span>
          <p class="text-2xl font-black text-[#009ee3] display-font mt-0.5"><%= formatPrice(order.total) %></p>
        </div>
      </div>

      <div class="p-6 sm:p-8 space-y-6">
        
        <!-- Simulation Warning -->
        <div class="bg-blue-50 border border-blue-150 rounded-2xl p-4 text-xs text-blue-700 leading-relaxed flex gap-3 items-start">
          <i class="fa-solid fa-circle-info text-blue-500 text-base mt-0.5 flex-shrink-0"></i>
          <div>
            <p class="font-bold mb-0.5">Entorno de Simulación Integrado</p>
            <p>
              Estás viendo este portal porque no has configurado un `MP_ACCESS_TOKEN` real en tu archivo `.env`. Este simulador reproduce el flujo completo de cobro de MercadoPago actualizando las bases de datos de forma correspondiente.
            </p>
          </div>
        </div>

        <!-- Receipt items mini container -->
        <div class="border border-slate-150 rounded-2xl p-4 space-y-2.5 bg-slate-50/50">
          <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">Detalle de Artículos</span>
          
          <div class="space-y-1.5 divide-y divide-slate-100 max-h-40 overflow-y-auto custom-scrollbar">
            <% order.products.forEach(item => { %>
              <div class="flex justify-between text-xs pt-1.5 first:pt-0">
                <span class="text-slate-650 truncate max-w-[250px]"><%= item.title %> (<%= item.quantity %> <%= item.unit %>)</span>
                <span class="font-semibold text-slate-800"><%= formatPrice(item.price * item.quantity) %></span>
              </div>
            <% }); %>
          </div>
        </div>

        <!-- Actions Form -->
        <form action="/payment/simulate-checkout" method="POST" class="space-y-3">
          <input type="hidden" name="orderId" value="<%= order._id %>">
          <input type="hidden" name="preferenceId" value="<%= preferenceId %>">
          
          <!-- Approve Button -->
          <button type="submit" name="action" value="approve" 
            class="w-full py-4 bg-[#009ee3] hover:bg-[#008ac6] text-white font-bold rounded-2xl shadow-md hover:shadow-lg transition-all flex items-center justify-center gap-2 text-sm">
            <i class="fa-solid fa-circle-check text-base"></i>
            Simular Pago Aprobado
          </button>
          
          <!-- Reject Button -->
          <button type="submit" name="action" value="reject" 
            class="w-full py-3.5 bg-white hover:bg-slate-50 text-rose-650 font-bold border border-rose-200 hover:border-rose-300 rounded-2xl transition-all flex items-center justify-center gap-2 text-sm">
            <i class="fa-solid fa-circle-xmark text-base"></i>
            Simular Pago Rechazado
          </button>
        </form>

      </div>

      <!-- Footer MP simulation link details -->
      <div class="bg-slate-50 px-6 py-4 text-center border-t border-slate-100">
        <a href="/cart" class="text-xs font-semibold text-slate-450 hover:text-slate-600 transition-colors">
          Cancelar pago y volver a AbastoHub
        </a>
      </div>

    </div>
  </main>

  <footer class="w-full py-4 text-center text-[10px] text-slate-400">
    Desarrollado para validación de flujo de pago en AbastoHub. 2026.
  </footer>

</body>
</html>
