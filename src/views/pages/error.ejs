<%- include('../partials/header') %>

<div class="max-w-xl mx-auto px-4 py-16 text-center">
  <div class="w-20 h-20 rounded-full bg-rose-50 border border-rose-100 flex items-center justify-center mx-auto mb-6 text-rose-500">
    <i class="fa-solid fa-triangle-exclamation text-3xl"></i>
  </div>
  
  <h1 class="display-font text-3xl font-extrabold text-slate-900 tracking-tight sm:text-4xl mb-2">
    <%= typeof title !== 'undefined' ? title : 'Ocurrió un error' %>
  </h1>
  <p class="text-slate-500 font-medium mb-1">Código de estado: <%= typeof status !== 'undefined' ? status : 500 %></p>
  
  <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm mb-8 text-left">
    <p class="text-slate-600 text-sm leading-relaxed">
      <%= typeof message !== 'undefined' ? message : 'Lo sentimos, se ha producido un error inesperado al procesar su solicitud.' %>
    </p>
    
    <% if (typeof stack !== 'undefined' && stack) { %>
      <div class="mt-4 pt-4 border-t border-slate-100">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2 display-font">Detalles técnicos (Desarrollo):</p>
        <pre class="bg-slate-50 p-3 rounded-lg text-[11px] font-mono text-slate-500 overflow-x-auto custom-scrollbar leading-relaxed"><%= stack %></pre>
      </div>
    <% } %>
  </div>

  <div class="flex flex-col sm:flex-row gap-3 justify-center">
    <a href="/" class="inline-flex justify-center items-center gap-2 px-6 py-2.5 rounded-full font-semibold text-white bg-brand-600 hover:bg-brand-700 shadow-md shadow-brand-500/10 transition-all duration-255 text-sm">
      <i class="fa-solid fa-house"></i>
      Volver al Inicio
    </a>
    <a href="/products" class="inline-flex justify-center items-center gap-2 px-6 py-2.5 rounded-full font-semibold text-slate-700 bg-white hover:bg-slate-55 border border-slate-200 shadow-sm transition-all duration-255 text-sm">
      Ir al Catálogo
    </a>
  </div>
</div>

<%- include('../partials/footer') %>
