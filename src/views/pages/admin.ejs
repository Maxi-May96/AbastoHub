<%- include('../partials/header') %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  
  <!-- Dashboard Heading -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-2 text-emerald-600">
      <i class="fa-solid fa-user-shield text-xl"></i>
      <span class="text-xs font-bold uppercase tracking-wider">Panel Administrativo Protegido</span>
    </div>
    <h1 class="display-font text-3xl font-extrabold tracking-tight text-slate-900">Panel de Control</h1>
    <p class="text-sm text-slate-500 mt-1">Crea productos, modifica stocks, activa/desactiva catálogo y visualiza los datos de compras y clientes.</p>
  </div>

  <!-- Messages Feedback -->
  <% if (success) { %>
    <div class="mb-6 bg-emerald-50 border border-emerald-100 text-emerald-700 p-4 rounded-2xl text-sm flex gap-2 items-center">
      <i class="fa-solid fa-circle-check text-base"></i>
      <span><%= success %></span>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="mb-6 bg-rose-50 border border-rose-100 text-rose-700 p-4 rounded-2xl text-sm flex gap-2 items-center">
      <i class="fa-solid fa-circle-exclamation text-base"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <!-- Tab selectors -->
  <div class="border-b border-slate-200 mb-8 overflow-x-auto">
    <nav class="flex gap-6 text-sm font-semibold min-w-max pb-1">
      <button onclick="switchTab('products-list-tab', this)" class="tab-btn pb-4 border-b-2 border-brand-650 text-brand-650" id="default-tab-btn">
        <i class="fa-solid fa-list-check mr-1.5 text-xs"></i>
        Productos & Stock
      </button>
      <button onclick="switchTab('new-product-tab', this)" class="tab-btn pb-4 border-b-2 border-transparent text-slate-400 hover:text-slate-600">
        <i class="fa-solid fa-circle-plus mr-1.5 text-xs"></i>
        Nuevo Producto
      </button>
      <button onclick="switchTab('orders-tab', this)" class="tab-btn pb-4 border-b-2 border-transparent text-slate-400 hover:text-slate-600">
        <i class="fa-solid fa-receipt mr-1.5 text-xs"></i>
        Pedidos & Datos Clientes
        <% if (orders && orders.length > 0) { %>
          <span class="ml-1 bg-slate-100 text-slate-600 text-[10px] px-2 py-0.5 rounded-full font-bold"><%= orders.length %></span>
        <% } %>
      </button>
      <button onclick="switchTab('partners-tab', this)" class="tab-btn pb-4 border-b-2 border-transparent text-slate-400 hover:text-slate-600">
        <i class="fa-solid fa-handshake mr-1.5 text-xs"></i>
        Socios & Afiliados
        <% if (partners && partners.length > 0) { %>
          <span class="ml-1 bg-slate-100 text-slate-600 text-[10px] px-2 py-0.5 rounded-full font-bold"><%= partners.length %></span>
        <% } %>
      </button>
      <button onclick="switchTab('new-partner-tab', this)" class="tab-btn pb-4 border-b-2 border-transparent text-slate-400 hover:text-slate-600">
        <i class="fa-solid fa-user-plus mr-1.5 text-xs"></i>
        Nuevo Socio/Afiliado
      </button>
    </nav>
  </div>

  <!-- Content Panels -->
  <div>
    
    <!-- Tab 1: Products List & Stock Editing -->
    <div id="products-list-tab" class="tab-panel space-y-6">
      <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
        
        <!-- Filters Header -->
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50 flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h2 class="text-base font-bold text-slate-800">Productos en Catálogo</h2>
            <p class="text-xs text-slate-400">Edita stock, destaca productos y aplica descuentos directamente.</p>
          </div>
          
          <div class="flex flex-wrap items-center gap-3">
            <!-- Text Search -->
            <div class="relative">
              <input type="text" id="admin-search-input" onkeyup="filterAdminProducts()" placeholder="Buscar producto..." 
                class="bg-white border border-slate-200 focus:border-brand-500/40 text-slate-800 placeholder-slate-400 px-3.5 py-1.5 pl-8 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-xs w-48">
              <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[10px]"></i>
            </div>

            <!-- Stock Range Filter -->
            <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-3 py-1.5 text-xs text-slate-600">
              <span class="font-semibold text-slate-500">Stock:</span>
              <input type="number" id="admin-stock-min" oninput="filterAdminProducts()" placeholder="Mín" min="0"
                class="w-12 bg-slate-50 border border-slate-200 rounded-md text-center py-0.5 outline-none focus:bg-white text-slate-700 font-bold">
              <span class="text-slate-400">-</span>
              <input type="number" id="admin-stock-max" oninput="filterAdminProducts()" placeholder="Máx" min="0"
                class="w-12 bg-slate-50 border border-slate-200 rounded-md text-center py-0.5 outline-none focus:bg-white text-slate-700 font-bold">
            </div>

            <!-- Reset Button -->
            <button onclick="clearAdminFilters()" class="px-3 py-1.5 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-650 hover:text-slate-850 text-xs font-bold transition-all">
              <i class="fa-solid fa-rotate-left mr-1 text-[10px]"></i>Limpiar
            </button>
          </div>
        </div>

        <div class="overflow-x-auto custom-scrollbar">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-semibold text-xs">
                <th class="px-6 py-4">Producto</th>
                <th class="px-6 py-4">Categoría</th>
                <th class="px-6 py-4">Precio Minorista / Mayorista</th>
                <th class="px-6 py-4">Stock Actual</th>
                <th class="px-6 py-4">Estado</th>
                <th class="px-6 py-4 text-center">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% if (products && products.length > 0) { %>
                <% products.forEach(prod => { %>
                  <tr class="product-row hover:bg-slate-50/50 transition-colors"
                      data-title="<%= prod.title.toLowerCase() %>"
                      data-stock="<%= prod.stock %>">
                    
                    <!-- Thumbnail & Title -->
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-12 h-10 bg-slate-50 border border-slate-100 rounded-lg flex items-center justify-center p-1 overflow-hidden flex-shrink-0">
                          <% if (prod.images && prod.images.length > 0) { %>
                            <img src="<%= prod.images[0] %>" alt="<%= prod.title %>" class="w-full h-full object-contain">
                          <% } else { %>
                            <i class="fa-regular fa-image text-slate-350 text-base"></i>
                          <% } %>
                        </div>
                        <div>
                          <p class="font-bold text-slate-800 line-clamp-1"><%= prod.title %></p>
                          <p class="text-[10px] text-slate-400">Venta por <%= prod.unit %></p>
                        </div>
                      </div>
                    </td>

                    <!-- Category -->
                    <td class="px-6 py-4 text-xs font-semibold text-slate-600">
                      <%= prod.category ? prod.category.name : 'N/A' %>
                    </td>

                    <!-- Pricing -->
                    <td class="px-6 py-4 text-xs font-semibold">
                      <span class="text-slate-800"><%= formatPrice(prod.price) %></span>
                      <span class="text-slate-300 mx-1">/</span>
                      <span class="text-brand-650 font-bold" title="Mayorista (6+ u.)"><%= formatPrice(prod.wholesalePrice) %></span>
                    </td>

                    <!-- Stock Inline Editor -->
                    <td class="px-6 py-4">
                      <form action="/admin/products/<%= prod._id %>/stock" method="POST" class="flex items-center gap-1.5">
                        <input type="number" name="stock" min="0" value="<%= prod.stock %>"
                          class="w-16 bg-slate-150 border border-slate-200 rounded-lg text-slate-800 font-bold px-2 py-1 text-xs text-center outline-none focus:border-brand-500/40 focus:bg-white focus:ring-4 focus:ring-brand-500/10">
                        <button type="submit" class="p-1 rounded-md text-slate-400 hover:text-brand-650 hover:bg-slate-100 transition-all" title="Guardar stock">
                          <i class="fa-solid fa-floppy-disk text-sm"></i>
                        </button>
                      </form>
                    </td>

                    <!-- Status Active -->
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold border <%= prod.active ? 'bg-emerald-50 text-emerald-700 border-emerald-100' : 'bg-slate-100 text-slate-500 border-slate-200' %>">
                        <%= prod.active ? 'Activo' : 'Pausado' %>
                      </span>
                      <% if (prod.featured) { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 border border-amber-100 ml-1">
                          ★ Destacado
                        </span>
                      <% } %>
                    </td>

                    <!-- Toggle & Delete Actions -->
                    <td class="px-6 py-4 text-center">
                      <div class="flex items-center justify-center gap-2 flex-wrap">
                        <form action="/admin/products/<%= prod._id %>/toggle" method="POST" class="inline">
                          <button type="submit" class="px-3 py-1.5 rounded-xl border text-xs font-bold transition-all <%= prod.active ? 'border-rose-100 hover:bg-rose-50 text-rose-600' : 'border-emerald-100 hover:bg-emerald-50 text-emerald-600' %>">
                            <%= prod.active ? 'Desactivar' : 'Activar' %>
                          </button>
                        </form>
                        <form action="/admin/products/<%= prod._id %>/toggle-featured" method="POST" class="inline">
                          <button type="submit" class="px-3 py-1.5 rounded-xl border text-xs font-bold transition-all <%= prod.featured ? 'border-amber-250 bg-amber-50 hover:bg-amber-100 text-amber-700' : 'border-slate-200 hover:bg-slate-50 text-slate-650' %>" title="<%= prod.featured ? 'Quitar destacado' : 'Destacar producto' %>">
                            <i class="fa-star <%= prod.featured ? 'fa-solid text-amber-500' : 'fa-regular' %> mr-1"></i><%= prod.featured ? 'Destacado' : 'Destacar' %>
                          </button>
                        </form>
                        <button type="button" 
                                onclick="changeDiscount('<%= prod._id %>', '<%= prod.discount || 0 %>')"
                                class="px-3 py-1.5 rounded-xl border text-xs font-bold transition-all <%= (prod.discount && prod.discount > 0) ? 'border-rose-200 bg-rose-50 hover:bg-rose-100 text-rose-700' : 'border-slate-200 hover:bg-slate-50 text-slate-650' %>" 
                                title="Aplicar descuento">
                          <i class="fa-solid fa-percent mr-1 text-[10px]"></i>
                          <%= (prod.discount && prod.discount > 0) ? `${prod.discount}% Off` : 'Descuento' %>
                        </button>
                        <form action="/admin/products/<%= prod._id %>/delete" method="POST" class="inline" onsubmit="return confirm('¿Estás seguro de que deseas eliminar permanentemente este producto del catálogo?')">
                          <button type="submit" class="px-3 py-1.5 rounded-xl border border-red-100 hover:bg-red-50 text-red-600 text-xs font-bold transition-all">
                            <i class="fa-solid fa-trash-can mr-1"></i>Eliminar
                          </button>
                        </form>
                      </div>
                    </td>

                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-slate-400">
                    No hay productos creados aún.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Tab 2: New Product Creation -->
    <div id="new-product-tab" class="tab-panel hidden max-w-2xl">
      <div class="bg-white border border-slate-200 rounded-3xl p-6 sm:p-8 shadow-sm">
        
        <form action="/admin/products" method="POST" enctype="multipart/form-data" class="space-y-5">
          
          <!-- Title -->
          <div>
            <label for="title" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Nombre del Producto *</label>
            <input type="text" id="title" name="title" required placeholder="E.g. Manzana Roja Selección"
              class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
          </div>

          <!-- Description -->
          <div>
            <label for="description" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Descripción (Opcional)</label>
            <textarea id="description" name="description" rows="3" placeholder="Detalla procedencia, tamaño, estado..."
              class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm resize-none"></textarea>
          </div>

          <!-- Pricing Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label for="price" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Precio Minorista * ($ ARS)</label>
              <input type="number" step="0.01" min="0" id="price" name="price" required placeholder="1250"
                class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
            </div>
            <div>
              <label for="wholesalePrice" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Precio Mayorista ($ ARS)</label>
              <input type="number" step="0.01" min="0" id="wholesalePrice" name="wholesalePrice" placeholder="980"
                class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
              <span class="text-[10px] text-slate-400 mt-1 block">Opcional. Si queda vacío, igual al minorista.</span>
            </div>
            <div>
              <label for="discount" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Descuento (%)</label>
              <input type="number" min="0" max="99" id="discount" name="discount" placeholder="0"
                class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
              <span class="text-[10px] text-slate-400 mt-1 block">Porcentaje (0-99). Opcional.</span>
            </div>
          </div>

          <!-- Stock, Unit, Category Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label for="stock" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Stock Inicial *</label>
              <input type="number" min="0" id="stock" name="stock" required placeholder="50"
                class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
            </div>
            
            <div>
              <label for="unit" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Unidad de Medida</label>
              <select id="unit" name="unit" 
                class="w-full bg-slate-50 border border-slate-200 text-slate-800 px-3 py-2.5 rounded-xl outline-none focus:border-brand-500/40 focus:ring-4 focus:ring-brand-500/10 text-sm">
                <option value="unidades">Unidades</option>
                <option value="kg">Kilos (kg)</option>
                <option value="cajón">Cajón</option>
                <option value="bolsa">Bolsa</option>
                <option value="pack">Pack</option>
              </select>
            </div>

            <div>
              <label for="categoryId" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Categoría *</label>
              <select id="categoryId" name="categoryId" required
                class="w-full bg-slate-50 border border-slate-200 text-slate-800 px-3 py-2.5 rounded-xl outline-none focus:border-brand-500/40 focus:ring-4 focus:ring-brand-500/10 text-sm">
                <% categories.forEach(cat => { %>
                  <option value="<%= cat._id %>"><%= cat.name %></option>
                <% }); %>
              </select>
            </div>
          </div>

          <!-- Image upload multi selector -->
          <div>
            <label for="images" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5 font-sans">Imágenes del Producto</label>
            <input type="file" id="images" name="images" multiple accept="image/*"
              class="w-full border border-slate-200 rounded-xl px-3 py-2 text-xs text-slate-500 bg-slate-50 outline-none file:mr-4 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 transition-all">
            <span class="text-[10px] text-slate-400 mt-1 block">Puedes seleccionar hasta 3 fotos. Formatos JPG/PNG de menos de 5MB.</span>
          </div>

          <!-- Checkboxes featured -->
          <div class="flex items-center">
            <input type="checkbox" id="featured" name="featured" value="true"
              class="h-4.5 w-4.5 text-brand-650 border-slate-350 focus:ring-brand-500/20 rounded">
            <label for="featured" class="ml-2 text-sm text-slate-650 font-medium">
              Destacar producto en la página de inicio
            </label>
          </div>

          <!-- Submit -->
          <div class="pt-2">
            <button type="submit" class="w-full py-3.5 bg-brand-600 hover:bg-brand-700 text-white font-bold rounded-xl shadow-md hover:shadow-lg shadow-brand-500/10 transition-all text-sm flex items-center justify-center gap-1.5">
              <i class="fa-solid fa-plus text-xs"></i>
              Crear Producto
            </button>
          </div>

        </form>

      </div>
    </div>

    <!-- Tab 3: Customer Orders & Contacts log -->
    <div id="orders-tab" class="tab-panel hidden space-y-6">
      <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
        
        <!-- Orders Header & Filters -->
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50 flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h2 class="text-base font-bold text-slate-800">Registro de Pedidos y Clientes</h2>
            <p class="text-xs text-slate-400">Visualiza transacciones, filtra por fecha y descarga reportes consolidados.</p>
          </div>
          
          <div class="flex flex-wrap items-center gap-3">
            <!-- Date range filter -->
            <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-3 py-1.5 text-xs text-slate-650 font-medium">
              <span class="font-bold text-slate-500">Desde:</span>
              <input type="date" id="admin-orders-start" onchange="filterAdminOrders()"
                class="bg-slate-50 border border-slate-200 rounded-lg px-2 py-1 outline-none focus:bg-white focus:border-brand-500/40 text-slate-700">
              <span class="font-bold text-slate-500">Hasta:</span>
              <input type="date" id="admin-orders-end" onchange="filterAdminOrders()"
                class="bg-slate-50 border border-slate-200 rounded-lg px-2 py-1 outline-none focus:bg-white focus:border-brand-500/40 text-slate-700">
            </div>

            <!-- PDF Download Button -->
            <a href="/admin/orders/report/pdf" id="download-orders-pdf-btn" target="_blank"
              class="px-4 py-2 rounded-xl bg-brand-600 hover:bg-brand-700 text-white text-xs font-bold transition-all flex items-center gap-1.5 shadow-sm hover:shadow">
              <i class="fa-solid fa-file-pdf"></i>Descargar Resumen PDF
            </a>

            <!-- Reset Button -->
            <button onclick="clearAdminOrdersFilters()" class="px-3 py-1.5 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-650 hover:text-slate-850 text-xs font-bold transition-all">
              <i class="fa-solid fa-rotate-left mr-1 text-[10px]"></i>Limpiar
            </button>
          </div>
        </div>

        <div class="overflow-x-auto custom-scrollbar">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-semibold text-xs">
                <th class="px-6 py-4">ID Pedido / Fecha</th>
                <th class="px-6 py-4">Cliente / Contacto</th>
                <th class="px-6 py-4">Artículos Comprados</th>
                <th class="px-6 py-4">Total</th>
                <th class="px-6 py-4">Método / Dirección</th>
                <th class="px-6 py-4">Pago</th>
                <th class="px-6 py-4 text-center">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% if (orders && orders.length > 0) { %>
                <% orders.forEach(order => { %>
                  <tr class="order-row hover:bg-slate-50/50 transition-colors" data-date="<%= order.createdAt.toISOString() %>">
                    
                    <!-- ID & Date -->
                    <td class="px-6 py-4">
                      <p class="font-bold text-slate-800">#<%= order._id.toString().substring(12) %></p>
                      <p class="text-[10px] text-slate-400 mt-0.5"><%= order.createdAt.toLocaleString('es-AR') %></p>
                      <% if (order.scheduledDate) { %>
                        <span class="mt-1.5 inline-flex items-center gap-1 px-2 py-0.5 bg-brand-50 text-brand-700 rounded-full text-[9px] font-bold border border-brand-100">
                          <i class="fa-solid fa-calendar-day text-[9px]"></i> Reserva: <%= order.scheduledDate.toLocaleDateString('es-AR') %>
                        </span>
                      <% } %>
                    </td>

                    <!-- Customer Info -->
                    <td class="px-6 py-4">
                      <% if (order.user) { %>
                        <p class="font-bold text-slate-800"><%= order.shippingDetails.name || `${order.user.name} ${order.user.lastname}` %></p>
                        <p class="text-[10px] text-slate-400 font-medium"><%= order.user.email %></p>
                        <p class="text-[10px] text-slate-400 mt-0.5"><i class="fa-solid fa-phone text-[9px] mr-1"></i><%= order.shippingDetails.phone || order.user.phone %></p>
                      <% } else { %>
                        <p class="font-bold text-rose-600">Usuario Eliminado</p>
                      <% } %>
                    </td>

                    <!-- Items snapshot -->
                    <td class="px-6 py-4">
                      <div class="space-y-0.5 max-w-xs text-xs text-slate-600">
                        <% order.products.forEach(item => { %>
                          <p class="truncate"><%= item.quantity %> × <%= item.title %> (<%= formatPrice(item.price) %>)</p>
                        <% }); %>
                      </div>
                    </td>

                    <!-- Total -->
                    <td class="px-6 py-4 font-black text-slate-800">
                      <%= formatPrice(order.total) %>
                    </td>

                    <!-- Delivery & Address -->
                    <td class="px-6 py-4 text-xs text-slate-600">
                      <p class="font-semibold"><%= order.deliveryType === 'delivery' ? 'Envío domicilio' : 'Retiro local' %></p>
                      <% if (order.deliveryType === 'delivery') { %>
                        <p class="text-[10px] text-slate-400 mt-1 line-clamp-2" title="<%= order.shippingDetails.address %>"><%= order.shippingDetails.address %></p>
                      <% } %>
                    </td>

                    <!-- Payment state badge -->
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold border 
                        <% if (order.paymentStatus === 'paid') { %> bg-emerald-50 text-emerald-700 border-emerald-100 
                        <% } else if (order.paymentStatus === 'pending') { %> bg-amber-50 text-amber-700 border-amber-100 
                        <% } else { %> bg-rose-50 text-rose-700 border-rose-100 <% } %>">
                        <%= order.paymentStatus.toUpperCase() %>
                      </span>
                      <% if (order.paymentId) { %>
                        <p class="text-[9px] text-slate-400 font-mono mt-1">MP: <%= order.paymentId.substring(0, 15) %>...</p>
                      <% } %>
                      <% if (order.paymentReceipt) { %>
                        <div class="mt-2">
                          <a href="<%= order.paymentReceipt %>" target="_blank" 
                            class="inline-flex items-center gap-1 px-2 py-1 bg-brand-50 hover:bg-brand-100 text-brand-700 rounded-lg text-[10px] font-bold border border-brand-100 transition-all"
                            title="Ver comprobante de pago subido por el cliente">
                            <i class="fa-solid fa-receipt text-[9px]"></i> Ver Compr.
                          </a>
                        </div>
                      <% } %>
                    </td>

                    <!-- Acciones (Ticket PDF & Aprobar Pago) -->
                    <td class="px-6 py-4 text-center">
                      <div class="flex flex-col sm:flex-row items-center justify-center gap-2">
                        <a href="/admin/orders/<%= order._id %>/pdf" target="_blank" 
                          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl border border-brand-100 hover:bg-brand-50 text-brand-650 text-xs font-bold transition-all" 
                          title="Imprimir Ticket de Preparación (PDF)">
                          <i class="fa-solid fa-file-pdf text-sm"></i> Ticket PDF
                        </a>
                        
                        <% if (order.paymentStatus !== 'paid') { %>
                          <form action="/admin/orders/<%= order._id %>/mark-paid" method="POST" class="inline"
                            onsubmit="return confirm('¿Está seguro de marcar este pedido como pagado? Esto actualizará el stock de los productos.');">
                            <button type="submit" 
                              class="inline-flex items-center gap-1 px-3 py-1.5 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold transition-all shadow-sm">
                              <i class="fa-solid fa-check text-[10px]"></i> Acreditar
                            </button>
                          </form>
                        <% } %>
                      </div>
                    </td>

                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="px-6 py-12 text-center text-slate-400">
                    No se registran transacciones.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Tab 4: Partners List -->
    <div id="partners-tab" class="tab-panel hidden space-y-6">
      <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
        <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between flex-wrap gap-4">
          <div>
            <h2 class="text-lg font-bold text-slate-800">Socios & Afiliados</h2>
            <p class="text-xs text-slate-400">Listado de marcas, socios y afiliados estratégicos de la tienda.</p>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200 text-slate-500 font-semibold text-xs">
                <th class="px-6 py-4">Logo</th>
                <th class="px-6 py-4">Nombre</th>
                <th class="px-6 py-4">Tipo</th>
                <th class="px-6 py-4">Enlace Web</th>
                <th class="px-6 py-4 text-center">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% if (partners && partners.length > 0) { %>
                <% partners.forEach(partner => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="px-6 py-4">
                      <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center p-1.5 overflow-hidden">
                        <img src="<%= partner.logo %>" alt="<%= partner.name %>" class="w-full h-full object-contain">
                      </div>
                    </td>
                    <td class="px-6 py-4 font-bold text-slate-800">
                      <%= partner.name %>
                    </td>
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold border capitalize 
                        <%= partner.type === 'socio' ? 'bg-indigo-50 text-indigo-700 border-indigo-100' : 'bg-teal-50 text-teal-700 border-teal-100' %>">
                        <%= partner.type %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-xs font-mono text-slate-500">
                      <% if (partner.website) { %>
                        <a href="<%= partner.website %>" target="_blank" class="text-brand-650 hover:underline"><%= partner.website %></a>
                      <% } else { %>
                        <span class="text-slate-400 font-sans">Sin enlace</span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-center">
                      <form action="/admin/partners/<%= partner._id %>/delete" method="POST" class="inline" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este socio/afiliado?')">
                        <button type="submit" class="px-3 py-1.5 rounded-xl border border-red-100 hover:bg-red-50 text-red-600 text-xs font-bold transition-all">
                          <i class="fa-solid fa-trash-can mr-1"></i>Eliminar
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="px-6 py-12 text-center text-slate-400">
                    No se registran socios ni afiliados activos.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Tab 5: New Partner/Affiliate Form -->
    <div id="new-partner-tab" class="tab-panel hidden space-y-6">
      <div class="bg-white border border-slate-200 rounded-3xl p-6 sm:p-8 shadow-sm">
        <h2 class="text-lg font-bold text-slate-800 mb-2">Nuevo Socio o Afiliado</h2>
        <p class="text-xs text-slate-400 mb-6">Agrega un nuevo socio comercial o afiliado estratégico para mostrar en el catálogo y página principal.</p>

        <form action="/admin/partners" method="POST" enctype="multipart/form-data" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Name -->
            <div>
              <label for="partner-name" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Nombre del Socio/Afiliado *</label>
              <input type="text" id="partner-name" name="name" required placeholder="E.g. Banco Provincia, Cooperativa Frutihortícola"
                class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
            </div>

            <!-- Type -->
            <div>
              <label for="partner-type" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Tipo *</label>
              <select id="partner-type" name="type" required
                class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
                <option value="socio">Socio Comercial / Sponsor</option>
                <option value="afiliado">Afiliado / Proveedor Oficial</option>
              </select>
            </div>
          </div>

          <!-- Website -->
          <div>
            <label for="partner-website" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Enlace del Sitio Web (Opcional)</label>
            <input type="url" id="partner-website" name="website" placeholder="https://www.ejemplo.com"
              class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
          </div>

          <!-- Logo Image -->
          <div>
            <label for="partner-logo" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">Imagen del Logo *</label>
            <input type="file" id="partner-logo" name="logo" required accept="image/*"
              class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/40 focus:bg-white text-slate-800 px-4 py-2.5 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
            <span class="text-[10px] text-slate-400 mt-1 block">Sube un logo con fondo transparente o blanco en formato PNG/JPG/SVG.</span>
          </div>

          <div class="pt-4 border-t border-slate-100 flex justify-end gap-3">
            <button type="reset" class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-650 hover:bg-slate-50 text-xs font-bold transition-all">
              Limpiar Campos
            </button>
            <button type="submit" class="px-5 py-2.5 rounded-xl bg-brand-650 hover:bg-brand-700 text-white text-xs font-bold transition-all shadow-sm">
              Agregar Socio / Afiliado
            </button>
          </div>
        </form>
      </div>
    </div>

  </div>

</div>

<!-- Tab switcher javascript logic -->
<form id="discount-action-form" method="POST" style="display: none;">
  <input type="hidden" name="discount" id="discount-form-value">
</form>

<script>
  function switchTab(tabId, buttonElement) {
    // Hide all panels
    const panels = document.querySelectorAll('.tab-panel');
    panels.forEach(p => p.classList.add('hidden'));

    // Show selected panel
    document.getElementById(tabId).classList.remove('hidden');

    // Reset button styles
    const buttons = document.querySelectorAll('.tab-btn');
    buttons.forEach(btn => {
      btn.className = "tab-btn pb-4 border-b-2 border-transparent text-slate-400 hover:text-slate-600";
    });

    // Highlight clicked button
    buttonElement.className = "tab-btn pb-4 border-b-2 border-brand-650 text-brand-650 font-bold";
  }

  function changeDiscount(productId, currentDiscount) {
    const val = prompt('Ingrese el porcentaje de descuento para el producto (0 para quitar el descuento):', currentDiscount);
    if (val === null) return; // User cancelled
    
    const discountNum = parseInt(val);
    if (isNaN(discountNum) || discountNum < 0 || discountNum >= 100) {
      alert('Por favor, ingrese un número válido entre 0 y 99.');
      return;
    }
    
    const form = document.getElementById('discount-action-form');
    form.action = `/admin/products/${productId}/discount`;
    document.getElementById('discount-form-value').value = discountNum;
    form.submit();
  }

  function filterAdminProducts() {
    const searchVal = document.getElementById('admin-search-input').value.toLowerCase().trim();
    const minVal = parseInt(document.getElementById('admin-stock-min').value);
    const maxVal = parseInt(document.getElementById('admin-stock-max').value);
    
    const rows = document.querySelectorAll('.product-row');
    
    rows.forEach(row => {
      const title = row.getAttribute('data-title') || '';
      const stock = parseInt(row.getAttribute('data-stock') || '0');
      
      let matchesSearch = true;
      if (searchVal && !title.includes(searchVal)) {
        matchesSearch = false;
      }
      
      let matchesMin = true;
      if (!isNaN(minVal) && stock < minVal) {
        matchesMin = false;
      }
      
      let matchesMax = true;
      if (!isNaN(maxVal) && stock > maxVal) {
        matchesMax = false;
      }
      
      if (matchesSearch && matchesMin && matchesMax) {
        row.classList.remove('hidden');
      } else {
        row.classList.add('hidden');
      }
    });
  }

  function clearAdminFilters() {
    document.getElementById('admin-search-input').value = '';
    document.getElementById('admin-stock-min').value = '';
    document.getElementById('admin-stock-max').value = '';
    filterAdminProducts();
  }

  function filterAdminOrders() {
    const startVal = document.getElementById('admin-orders-start').value;
    const endVal = document.getElementById('admin-orders-end').value;
    
    // Update PDF download link with selected dates
    const pdfBtn = document.getElementById('download-orders-pdf-btn');
    let pdfUrl = '/admin/orders/report/pdf';
    const params = [];
    if (startVal) params.push(`startDate=${startVal}`);
    if (endVal) params.push(`endDate=${endVal}`);
    if (params.length > 0) {
      pdfUrl += '?' + params.join('&');
    }
    pdfBtn.href = pdfUrl;

    // Filter table rows
    const rows = document.querySelectorAll('.order-row');
    
    let startDate = startVal ? new Date(startVal + 'T00:00:00') : null;
    let endDate = endVal ? new Date(endVal + 'T23:59:59') : null;
    
    rows.forEach(row => {
      const dateStr = row.getAttribute('data-date');
      if (!dateStr) return;
      
      const orderDate = new Date(dateStr);
      let matchesStart = true;
      if (startDate && orderDate < startDate) {
        matchesStart = false;
      }
      
      let matchesEnd = true;
      if (endDate && orderDate > endDate) {
        matchesEnd = false;
      }
      
      if (matchesStart && matchesEnd) {
        row.classList.remove('hidden');
      } else {
        row.classList.add('hidden');
      }
    });
  }

  function clearAdminOrdersFilters() {
    document.getElementById('admin-orders-start').value = '';
    document.getElementById('admin-orders-end').value = '';
    filterAdminOrders();
  }
</script>

<%- include('../partials/footer') %>
