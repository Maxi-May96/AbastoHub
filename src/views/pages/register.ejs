<%- include('../partials/header') %>

<div class="min-h-[80vh] flex flex-col justify-center py-12 sm:px-6 lg:px-8 bg-slate-100/50">
  <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
    <div class="w-12 h-12 rounded-2xl bg-brand-600 flex items-center justify-center mx-auto mb-4 shadow-lg shadow-brand-500/10">
      <i class="fa-solid fa-user-plus text-white text-lg"></i>
    </div>
    <h2 class="display-font text-3xl font-extrabold text-slate-900 tracking-tight">
      Crear Cuenta de Cliente
    </h2>
    <p class="mt-2 text-sm text-slate-500">
      ¿Ya eres parte de AbastoHub?
      <a href="/login" class="font-semibold text-brand-600 hover:text-brand-700 transition-colors">
        Inicia sesión aquí
      </a>
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-lg px-4">
    <div class="bg-white py-8 px-6 sm:px-10 rounded-3xl border border-slate-200/80 shadow-xl shadow-slate-100/40">
      
      <!-- Error Alerts -->
      <% if (errors && errors.length > 0) { %>
        <div class="mb-5 bg-rose-50 border border-rose-100 text-rose-700 p-4 rounded-xl text-sm space-y-1">
          <p class="font-bold flex items-center gap-1"><i class="fa-solid fa-circle-exclamation text-base"></i> Hubo errores en el formulario:</p>
          <ul class="list-disc pl-5 space-y-0.5">
            <% errors.forEach(err => { %>
              <li><%= err %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <form class="space-y-5" action="/register" method="POST">
        
        <!-- Name & Lastname Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">
              Nombre
            </label>
            <input id="name" name="name" type="text" required placeholder="Carlos"
              value="<%= typeof inputData !== 'undefined' && inputData.name ? inputData.name : '' %>"
              class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/50 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
          </div>
          <div>
            <label for="lastname" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">
              Apellido
            </label>
            <input id="lastname" name="lastname" type="text" required placeholder="Pérez"
              value="<%= typeof inputData !== 'undefined' && inputData.lastname ? inputData.lastname : '' %>"
              class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/50 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
          </div>
        </div>

        <!-- Contact Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="email" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">
              Correo Electrónico
            </label>
            <input id="email" name="email" type="email" required placeholder="carlos@correo.com"
              value="<%= typeof inputData !== 'undefined' && inputData.email ? inputData.email : '' %>"
              class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/50 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
          </div>
          <div>
            <label for="phone" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">
              Teléfono (WhatsApp)
            </label>
            <input id="phone" name="phone" type="text" required placeholder="+541155550199"
              value="<%= typeof inputData !== 'undefined' && inputData.phone ? inputData.phone : '' %>"
              class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/50 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
          </div>
        </div>

        <!-- Password -->
        <div>
          <label for="password" class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1.5">
            Contraseña (Mínimo 6 caracteres)
          </label>
          <input id="password" name="password" type="password" required placeholder="******"
            class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/50 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
        </div>

        <!-- Shipping address fields -->
        <div class="pt-2 border-t border-slate-100">
          <span class="block text-[10px] font-extrabold uppercase tracking-wider text-slate-450 mb-3 display-font">
            Dirección de Envío Principal
          </span>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="address_street" class="block text-xs font-semibold text-slate-500 mb-1">
                Calle y Número
              </label>
              <input id="address_street" name="address_street" type="text" placeholder="Av. Corrientes 1234"
                value="<%= typeof inputData !== 'undefined' && inputData.address_street ? inputData.address_street : '' %>"
                class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/50 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
            </div>
            <div>
              <label for="address_city" class="block text-xs font-semibold text-slate-500 mb-1">
                Localidad / Ciudad
              </label>
              <input id="address_city" name="address_city" type="text" placeholder="CABA"
                value="<%= typeof inputData !== 'undefined' && inputData.address_city ? inputData.address_city : '' %>"
                class="w-full bg-slate-50 border border-slate-200 focus:border-brand-500/50 focus:bg-white text-slate-800 placeholder-slate-400 px-4 py-2 rounded-xl outline-none focus:ring-4 focus:ring-brand-500/10 transition-all text-sm">
            </div>
          </div>
        </div>

        <div>
          <button type="submit" class="w-full py-3 px-4 rounded-xl bg-brand-600 hover:bg-brand-700 text-white font-bold shadow-md shadow-brand-500/10 hover:shadow-lg transition-all text-sm flex items-center justify-center gap-2">
            Registrarme y Comenzar Compra
            <i class="fa-solid fa-user-check text-xs"></i>
          </button>
        </div>
      </form>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
